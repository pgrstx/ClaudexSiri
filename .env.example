# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Picovoice for better wake word detection ────────────────────────
# Get a free key at console.picovoice.ai
# PICOVOICE_ACCESS_KEY=

# ── Whisper model size (tiny / base / small / medium) ─────────────────────────
WHISPER_MODEL=base

# ── Wake word engine: "whisper" (default, offline) or "porcupine" ─────────────
WAKE_WORD_ENGINE=whisper

# ── Claude model ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6

# ── macOS TTS voice ───────────────────────────────────────────────────────────
# List voices: say -v '?'
TTS_VOICE=Samantha
TTS_RATE=210
